DJANGO_SECRET_KEY=replace-with-secure-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,local.hotel.test
DJANGO_TIME_ZONE=UTC
DJANGO_ADMIN_URL=admin/
DJANGO_SERVE_LOCAL_STATIC=True
CORS_ALLOW_ALL_ORIGINS=True

# Native Windows/local script defaults.
POSTGRES_DB=hotelmgmt
POSTGRES_USER=hotelmgmt_user
POSTGRES_PASSWORD=hotelmgmt_pass
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Production deployments should set DATABASE_URL instead of the POSTGRES_* values.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DJANGO_DEBUG=False
# DJANGO_STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage
# DJANGO_SERVE_LOCAL_STATIC=False
# CSRF_TRUSTED_ORIGINS=https://your-backend.example.com
